# ─── Contact Form (Nodemailer) ───────────────────────────────────────────────

# SMTP host — use smtp.gmail.com for Gmail
SMTP_HOST=smtp.gmail.com

# 587 for STARTTLS (recommended), 465 for SSL
SMTP_PORT=587

# The email account you're sending FROM
SMTP_USER=your_email@gmail.com

# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
# (requires 2FA to be enabled on your Google account)
SMTP_PASS=your_app_password_here

# Display name and sending address in the From header
SMTP_FROM="Sandeep Portfolio <your_email@gmail.com>"

# Where you want to receive contact form messages
CONTACT_TO_EMAIL=""

# ─── Optional: Add more vars here as needed ───────────────────────────────────

# Example: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
